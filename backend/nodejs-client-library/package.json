{
  "name": "@chaosity/nodejs-client-library",
  "version": "1.0.0",
  "description": "Location Service with client library and getToken() method",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "build": "tsc",
    "test": "vitest",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\""
  },
  "dependencies": {
    "@chaosity/location-client": "^0.1.14",
    "express": "^4.18.2",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.0.4",
    "@eslint/js": "^9.28.0",
    "eslint": "^9.28.0",
    "typescript-eslint": "^8.34.0",
    "prettier": "^3.6.2"
  }
}
